---
import '../styles/global.css';
import Reveal from '../components/AnimatedCard';
import PremiumAudioPlayer from '../components/PremiumAudioPlayer';
import ConfigModal from '../components/ConfigModal';
import TimelineTabs from '../components/TimelineTabs';
import ProjectList from '../components/ProjectList';
import { useTranslations } from '../i18n/ui';
import { cvData } from '../data/cv';
import { getCollection } from 'astro:content';

interface Props {
  lang: 'es' | 'en';
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const d = cvData[lang];

// We need to pass translated labels to the React component
const timelineLabels = {
  exp: t('section.experience'),
  edu: t('section.education'),
  blog: t('section.publications'),
  awd: t('section.awards')
};

const blogs = await getCollection('blog');
// Sort blogs by date
const sortedBlogs = blogs.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// SEO Setup
const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? Astro.url);
const siteName = "Cesar Acjota | Portfolio";
const defaultImage = "/og-image.webp"; // Placeholder for their real OG image

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Cesar Acjota",
  "url": Astro.url.origin,
  "image": "https://avatars.githubusercontent.com/u/81894363?v=4",
  "jobTitle": "Data Engineer & Developer",
  "alumniOf": "National University of San Agustin",
  "sameAs": [
    "https://github.com/cesaracjota",
    "https://www.linkedin.com/in/cesaracjota/"
  ]
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{d.name} — {d.role}</title>
    <meta name="description" content={d.about} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Fonts: Bricolage Grotesque (Display), Inter (Sans), JetBrains Mono (Mono) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400..800&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />

    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={`${d.name} — ${d.role}`} />
    <meta property="og:description" content={d.about} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:image" content={new URL(defaultImage, Astro.url)} />
    <meta property="og:locale" content={lang === 'es' ? 'es_PE' : 'en_US'} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={`${d.name} — ${d.role}`} />
    <meta property="twitter:description" content={d.about} />
    <meta property="twitter:image" content={new URL(defaultImage, Astro.url)} />

    <!-- Robots -->
    <meta name="robots" content="index, follow" />
    
    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />

    <!-- Inline script to prevent FOUC when loading light/dark mode and color theme -->
    <script is:inline>
      const theme = localStorage.getItem('theme');
      if (theme === 'dark' || (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark');
      } else {
        document.documentElement.classList.remove('dark');
      }

      const colorTheme = localStorage.getItem('colorTheme') || 'zinc';
      document.documentElement.classList.add(`theme-${colorTheme}`);
    </script>
  </head>
  <body>

    <!-- ══════ MAIN CONTENT ══════ -->
    <div class="relative z-10 max-w-[800px] mx-auto px-6 md:px-8 pt-6 pb-20 md:pt-10 md:pb-32 page-fade-in">

      <!-- ── HERO ── -->
      <header class="mb-16 flex flex-col items-center text-center">
        <Reveal client:visible variant="scale">
          <!-- Avatar with availability pulse ring -->
          <div class="mb-6 inline-block relative">
            <!-- Pulsing ring for availability -->
            <span class="absolute inset-0 rounded-full animate-ping opacity-20" style="background: rgba(16, 185, 129, 0.4); animation-duration: 2.8s;"></span>
            <div class="rounded-full p-[3px] bg-gradient-to-tr from-[var(--color-border)] to-[var(--color-surface)] shadow-xl inline-block">
              <img 
                src={d.avatar} 
                alt={d.name} 
                width="128" 
                height="128" 
                decoding="async"
                class="w-24 h-24 md:w-32 md:h-32 rounded-full object-cover border-4 border-[var(--color-bg)] hover:scale-[1.03] transition-transform duration-500" 
              />
            </div>
            <!-- Online indicator dot -->
            <span class="absolute bottom-2 right-2 w-4 h-4 bg-emerald-500 border-2 border-[var(--color-bg)] rounded-full shadow-sm"></span>
          </div>
        </Reveal>

        <Reveal client:visible delay={1}>
          <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold tracking-[-0.03em] leading-[1.05] mb-6 text-[var(--color-text-main)]">
            {d.name}
          </h1>
        </Reveal>

        <Reveal client:visible delay={2}>
          <p class="text-xl md:text-2xl font-display font-semibold text-[var(--color-accent)] mb-6">
            Data Engineer & Developer
          </p>
        </Reveal>

        <Reveal client:visible delay={3}>
          <p class="text-base text-[var(--color-text-secondary)] leading-relaxed mb-8 max-w-2xl mx-auto">
            {d.about}
          </p>
        </Reveal>

        <!-- Social links -->
        <Reveal client:visible delay={4}>
          <nav class="flex flex-wrap items-center justify-center gap-4">
            <a href="/CV.cesaracjota.pdf" target="_blank" rel="noopener" class="social-link" aria-label="CV">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
              Ver CV
            </a>
            <a href={`mailto:${d.email}`} class="social-link" aria-label="Email">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              Email
            </a>
            <a href={d.github} target="_blank" rel="noopener" class="social-link" aria-label="GitHub">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
              GitHub
            </a>
            <a href={d.linkedin} target="_blank" rel="noopener" class="social-link" aria-label="LinkedIn">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
              LinkedIn
            </a>
          </nav>
        </Reveal>

        <Reveal client:visible delay={5}>
          <PremiumAudioPlayer client:load />
        </Reveal>
      </header>

      <!-- ── SKILLS ── -->
      <section class="mb-20">
        <Reveal client:visible>
          <h2 class="section-heading">
            <svg class="w-5 h-5 text-[var(--color-text-main)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m18 16 4-4-4-4"/><path d="m6 8-4 4 4 4"/><path d="m14.5 4-5 16"/></svg>
            {t('section.skills')}
          </h2>
        </Reveal>
        <Reveal client:visible delay={1} variant="fade">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            {Object.entries(d.skills).map(([cat, items], catIdx) => (
              <div class="bg-[var(--color-surface)] border border-[var(--color-border)] p-5 rounded-xl hover:border-[var(--color-border-hover)] transition-colors duration-200 group">
                <span class="block text-[10px] font-mono text-[var(--color-accent)] mb-3 uppercase tracking-[0.1em] opacity-80 group-hover:opacity-100 transition-opacity">{cat}</span>
                <div class="flex flex-wrap gap-2">
                  {(items as string[]).map((skill) => (
                    <span class="skill-badge">{skill}</span>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </Reveal>
      </section>

      <!-- ── TIMELINE (EXP / EDU TABS) ── -->
      <section class="mb-20">
        <Reveal client:visible>
          <h2 class="section-heading">
            <svg class="w-5 h-5 text-[var(--color-text-main)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/><path d="M12 6v6l4 2"/></svg>
            Journey
          </h2>
        </Reveal>
        <Reveal client:visible delay={1}>
          {/* React component handling state and animation between Exp, Edu, and Blogs */}
          <TimelineTabs 
            client:visible 
            labels={timelineLabels} 
            experience={d.experience} 
            education={d.certifications}
            blogs={sortedBlogs}
            awards={d.awards}
          />
        </Reveal>
      </section>

      <!-- ── PROJECTS (IMAGE CARDS) ── -->
      <section class="mb-20">
        <Reveal client:visible>
          <h2 class="section-heading">
            <svg class="w-5 h-5 text-[var(--color-text-main)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.29 7 12 12 20.71 7"/><polyline points="12 22 12 12"/></svg>
            {t('section.projects')}
          </h2>
        </Reveal>
        
        <ProjectList 
          client:visible 
          projects={d.projects} 
          loadMoreText={lang === 'es' ? 'Ver Más Proyectos' : 'Load More Projects'} 
          codeText={t('project.github')}
          demoText={t('project.demo')}
          previewText={t('project.preview')}
        />
      </section>

      <!-- ── FOOTER ── -->
      <footer class="text-center">
        <p class="text-sm font-medium text-[var(--color-text-muted)]">
          © {new Date().getFullYear()} {d.name}
        </p>
      </footer>

    </div>

    <!-- Floating Configuration Modal -->
    <ConfigModal currentLang={lang} client:load />
  </body>
</html>
